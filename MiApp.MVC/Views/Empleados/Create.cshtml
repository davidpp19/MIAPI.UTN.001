@using MiAPI.UTN.Modelos;
@model Empleado

@{
    ViewData["Title"] = "Nueva Persona";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Nuevo Empleado</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Salario" class="form-label"></label>
        <input asp-for="Salario" class="form-control" />
        <span asp-validation-for="Salario" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Comision" class="form-label"></label>
        <input asp-for="Comision" class="form-control" />
        <span asp-validation-for="Comision" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FechaIngreso" class="form-label"></label>
        <textarea asp-for="FechaIngreso" class="form-control" rows="3"></textarea>
        <span asp-validation-for="FechaIngreso" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PersonaId" class="control-label">Pais</label>
        <select asp-for="PersonaId" class="form-control" asp-items="ViewBag.Persona">
            <option value="">Seleccion Persona</option>
        </select>
        <span asp-validation-for="PersonaId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CargoId" class="control-label">Pais</label>
        <select asp-for="CargoId" class="form-control" asp-items="ViewBag.Cargo">
            <option value="">Seleccion Cargo</option>
        </select>
        <span asp-validation-for="CargoId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}