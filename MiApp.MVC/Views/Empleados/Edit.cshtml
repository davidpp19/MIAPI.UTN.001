@using MiAPI.UTN.Modelos;

@model Empleado

@{
    ViewData["Title"] = "Editar Empleado";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Empleado</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input asp-for="Id" type="hidden" />

    <div class="form-group">
        <label asp-for="Persona" class="control-label">Persona</label>
        <select asp-for="PersonaId" class="form-control" asp-items="@ViewBag.selectListPersonas">
            <option value="">-- Seleccion Persona --</option>
        </select>
        <span asp-validation-for="Persona" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Cargo" class="control-label">Cargo</label>
        <select asp-for="CargoId" class="form-control" asp-items="@ViewBag.selectListCargos">
            <option value="">-- Seleccion Cargo --</option>
        </select>
        <span asp-validation-for="Cargo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FechaIngreso" class="form-label"></label>
        <input asp-for="FechaIngreso" class="form-control" />
        <span asp-validation-for="FechaIngreso" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Salario" class="form-label"></label>
        <input asp-for="Salario" class="form-control" />
        <span asp-validation-for="Salario" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Comision" class="form-label"></label>
        <input asp-for="Comision" class="form-control" />
        <span asp-validation-for="Comision" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}